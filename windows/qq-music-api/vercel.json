{
  "buildCommand": "npm run vercel-build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/docs-dist/index.html"
    },
    {
      "src": "/(guide|api|reference)",
      "dest": "/docs-dist/$1/index.html"
    },
    {
      "src": "/(guide|api|reference)/(.*)",
      "dest": "/docs-dist/$1/$2"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/docs-dist/assets/$1"
    },
    {
      "src": "\\.(html|css|js|png|jpg|svg|woff2|json)$",
      "dest": "/docs-dist$&"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ]
}
